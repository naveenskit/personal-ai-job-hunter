# Environment example for Personal AI Job Hunter
# Copy to `.env` and update secrets before running in development or production.

# App environment: development | test | production
ENVIRONMENT=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Application secret keys
APP_SECRET_KEY=change-me
API_SECRET_KEY=change-me

# Database URL (SQLAlchemy)
# Example: sqlite+aiosqlite:///./data/jobhunter.db
DATABASE_URL=sqlite+aiosqlite:///./data/jobhunter.db

# Gemini AI API key (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Telegram bot integration (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# AI
# Google Gemini API key used by the default AI provider.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Telegram
# Bot token and personal chat id for daily digests and commands.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database
# SQLite now; switch to PostgreSQL later without changing business logic.
DATABASE_URL=sqlite+aiosqlite:///./data/jobhunter.db

# App
APP_SECRET_KEY=change-me
API_SECRET_KEY=change-me
LOG_LEVEL=INFO
ENVIRONMENT=development
TIMEZONE=Asia/Kolkata

# Runtime
DATA_DIR=./data
LOG_DIR=./logs
EXPORT_DIR=./exports
